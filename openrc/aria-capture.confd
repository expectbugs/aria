# ARIA Ambient Capture configuration for OpenRC
# This service runs on slappy (laptop) only.
# Ensure AMBIENT_CAPTURE_ENABLED=True in config.py before starting.

# PipeWire/PulseAudio needs the user's session context for Bluetooth audio.
# supervise-daemon passes these to the process environment.
export XDG_RUNTIME_DIR="/run/user/1000"
export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/1000/bus"
